APP_NAME="Metrolinea AI"
APP_ENV=dev
LOG_LEVEL=INFO

# Modelo YOLO usado para conteo de personas
YOLO_MODEL=yolov8n.pt

# Umbrales del motor de decisión
OCCUPANCY_THRESHOLD=0.85       # >85% lleno → señal de saturación
DELAY_THRESHOLD_MIN=8          # >8 min de retraso en una parada → señal
DISPATCH_COOLDOWN_MIN=10       # No despachar más de un refuerzo cada 10 min

# Datos
DATA_DIR=/srv/data
