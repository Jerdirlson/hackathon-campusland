APP_NAME="Metrolinea AI"
APP_ENV=dev
LOG_LEVEL=INFO

# Modelo YOLO usado para conteo de personas
YOLO_MODEL=yolov8n.pt

# Umbrales del motor de decisión
OCCUPANCY_THRESHOLD=0.85
DELAY_THRESHOLD_MIN=8
DISPATCH_COOLDOWN_MIN=10

# Datos
DATA_DIR=/srv/data

# PostgreSQL
POSTGRES_DB=metrolinea
POSTGRES_USER=metrolinea
POSTGRES_PASSWORD=metrolinea
DATABASE_URL=postgresql://metrolinea:metrolinea@postgres:5432/metrolinea

# Backend
PORT=3000
NODE_ENV=development

# OpenAI
OPENAI_API_KEY=

# Auth
JWT_SECRET=change-me-in-production
